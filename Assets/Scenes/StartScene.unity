  m_text: "- \u041F\u0440\u0435\u0434\u043C\u0435\u0442\u044B, \u0431\u0440\u043E\u0448\u0435\u043D\u043D\u044B\u0435
    \u043D\u0430 \u0437\u0435\u043C\u043B\u044E \u0440\u0430\u0437\u043B\u0430\u0433\u0430\u044E\u0442\u0441\u044F
    \u0438 \u043F\u043E\u0432\u044B\u0448\u0430\u044E\u0442 \u0437\u0430\u0433\u0440\u044F\u0437\u043D\u0435\u043D\u0438\u0435.
    \u041E\u0442\u043D\u043E\u0441\u0438\u0442\u0435 \u0438\u0445 \u0432 \u043C\u0443\u0441\u043E\u0440\u043D\u044B\u0439
    \u0431\u0430\u043A \u0440\u044F\u0434\u043E\u043C \u0441\u043E \u0432\u0445\u043E\u0434\u043E\u043C;\n-
    \u0414\u043B\u044F \u043E\u0447\u0438\u0449\u0435\u043D\u0438\u044F \u043F\u0440\u0438\u0440\u043E\u0434\u044B
    \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u0444\u0438\u043B\u044C\u0442\u0440. \u041C\u0435\u0441\u0442\u043E \u0434\u043B\u044F
    \u0435\u0433\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0439\u043A\u0438 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u043D\u0430 \u0443\u043B\u0438\u0446\u0435 \u0437\u0430 \u043A\u0430\u0444\u0435
    \u0443 \u043F\u0440\u0430\u0432\u043E\u0439 \u0441\u0442\u0435\u043D\u044B;\n-
    \u041C\u043E\u0436\u043D\u043E \u0443\u0431\u0440\u0430\u0442\u044C \u0432\u0435\u0441\u044C
    \u043C\u0443\u0441\u043E\u0440 \u0441 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438,
    \u043F\u043E\u0434\u043E\u0439\u0434\u044F \u043A \u043C\u0443\u0441\u043E\u0440\u043D\u043E\u043C\u0443
    \u0431\u0430\u0443\u043A \u0438 \u043D\u0430\u0436\u0430\u0432 \u043D\u0430 \u0438\u043A\u043E\u043D\u043A\u0443
    \u043C\u0443\u0441\u043E\u0440\u043E\u0432\u043E\u0437\u0430. \u041F\u0440\u0430\u0432\u0434\u0430
    \u0437\u0430 \u044D\u0442\u043E \u043F\u0440\u0438\u0434\u0451\u0442\u0441\u044F
    \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u0442\u044C \u0438\u0437 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0434\u0435\u043D\u0435\u0433."
