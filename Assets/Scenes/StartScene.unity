--- !u!114 &848488538
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 848488536}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041A\u0430\u043A \u0438\u0433\u0440\u0430\u0442\u044C:\n- \u0414\u043B\u044F
    \u043D\u0430\u0447\u0430\u043B\u0430 \u043F\u0440\u043E\u0439\u0434\u0438\u0442\u0435
    \u043A \u0433\u0440\u044F\u0434\u043A\u0435 \u0438 \u0432\u043E\u0437\u044C\u043C\u0438\u0442\u0435
    \u0441 \u043D\u0435\u0451 \u0441\u0432\u0435\u0436\u0438\u0435 \u043E\u0432\u043E\u0449\u0438.
    \u0413\u0440\u044F\u0434\u043A\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u043D\u0430 \u0443\u043B\u0438\u0446\u0435, \u0443 \u043D\u0438\u0436\u043D\u0435\u0439
    \u0441\u0442\u0435\u043D\u044B \u043A\u0430\u0444\u0435.\n- \u041E\u0442\u043D\u0435\u0441\u0438\u0442\u0435
    \u044F\u0449\u0438\u043A \u0441 \u043E\u0432\u043E\u0449\u0430\u043C\u0438 \u043A
    \u0441\u0442\u043E\u043B\u0443 \u043D\u0430 \u043A\u0443\u0445\u043D\u0435 (\u0434\u0432\u0430
    \u0431\u0435\u043B\u044B\u0445 \u0441\u0442\u043E\u043B\u0430 \u0440\u044F\u0434\u043E\u043C
    \u0441 \u0445\u043E\u043B\u043E\u0434\u0438\u043B\u044C\u043D\u0438\u043A\u043E\u043C)\n-
    \u041A\u043E\u0433\u0434\u0430 \u043E\u0432\u043E\u0449\u0438 \u0431\u0443\u0434\u0443\u0442
    \u0434\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u044B \u043A \u0441\u0442\u043E\u043B\u0443,
    \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E
    \u0441\u0432\u0435\u0436\u0438\u0445 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u043E\u0432
    (\u0438\u0437 \u043E\u0434\u043D\u043E\u0433\u043E \u044F\u0449\u0438\u043A\u0430
    \u043E\u0432\u043E\u0449\u0435\u0439 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442\u0441\u044F
    \u0434\u0432\u0435 \u043F\u043E\u0440\u0446\u0438\u0438 \u0441\u0432\u0435\u0436\u0438\u0445
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u043E\u0432). \u0427\u0435\u0440\u0435\u0437
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0435\u043A\u0443\u043D\u0434
    \u043E\u0432\u043E\u0449\u0438 \u0431\u0443\u0434\u0443\u0442 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u044B
    \u043A \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u0439 \u0433\u043E\u0442\u043E\u0432\u043A\u0435.\n-
    \u041E\u0442\u043D\u0435\u0441\u0438\u0442\u0435 \u0441\u0432\u0435\u0436\u0438\u0435
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u044B \u043A \u043F\u043B\u0438\u0442\u0435.
    \u041D\u0430\u0447\u043D\u0451\u0442\u0441 \u044F\u043F\u0440\u043E\u0446\u0435\u0441\u0441
    \u043F\u0440\u0438\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u044F
    \u0444\u0438\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0431\u043B\u044E\u0434\u0430.
    \u041E\u043D\u0438 \u043F\u043E\u044F\u0432\u044F\u0442\u0441\u044F \u043D\u0430
    \u043F\u043B\u0438\u0442\u0435 \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0441\u0435\u043A\u0443\u043D\u0434.\n- \u041E\u0442\u043D\u0435\u0441\u0438\u0442\u0435
    \u0433\u043E\u0442\u043E\u0432\u043E\u0435 \u0431\u043B\u044E\u0434\u043E \u043A
    \u0441\u0442\u043E\u043B\u0443 \u0434\u043B\u044F \u0440\u0430\u0437\u0434\u0430\u0447\u0438.
    \u041A\u043E\u0433\u0434\u0430 \u043A \u0441\u0442\u043E\u043B\u0443 \u043F\u043E\u0434\u043E\u0439\u0434\u0451\u0442
    \u043A\u043B\u0438\u0435\u043D\u0442, \u043E\u043D \u0437\u0430\u0431\u0435\u0440\u0451\u0442
    \u0431\u043B\u044E\u0434\u043E \u0438 \u043F\u043E\u0439\u0434\u0451\u0442 \u0441
    \u043D\u0438\u043C \u043A \u043A\u0430\u0441\u0441\u0435.\n- \u041F\u043E\u0434\u043E\u0439\u0434\u0438\u0442\u0435
    \u043A \u043A\u0430\u0441\u0441\u0435 \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435
    \u043A\u043D\u043E\u043F\u043A\u0443 \"\u041F\u0440\u0438\u043D\u044F\u0442\u044C
    \u043E\u043F\u043B\u0430\u0442\u0443\".\n\u0413\u043E\u0442\u043E\u0432\u043E!
    \u0414\u0435\u043D\u044C\u0433\u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B\u0438
    \u0432 \u043A\u0430\u0441\u0441\u0443, \u0430 \u043A\u043B\u0438\u0435\u043D\u0442
    \u0438\u0434\u0451\u0442 \u043E\u0431\u0435\u0434\u0430\u0442\u044C."
